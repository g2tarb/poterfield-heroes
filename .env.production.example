# =============================================================================
# Porterfield Heroes — Production secrets (DO NOT COMMIT)
# Copy to .env.production and fill in values.
# =============================================================================

# --- Database ---
POSTGRES_USER=ph
POSTGRES_PASSWORD=                    # openssl rand -base64 32
POSTGRES_DB=porterfield

# --- Auth (mono-user) ---
SESSION_SECRET=                       # openssl rand -hex 32 (32+ chars)
ACCESS_PASSWORD=                      # ton mot de passe perso

# --- Web/API URLs (CORS doit matcher l'URL publique du web) ---
CORS_ORIGIN=https://porterfield.tondomaine.com
PUBLIC_API_URL=https://api.porterfield.tondomaine.com

# --- IA Providers ---
ANTHROPIC_API_KEY=sk-ant-api03-xxx
VOYAGE_API_KEY=pa-xxx

# --- Budget cap (cents/month) ---
MONTHLY_AI_BUDGET_CENTS=5000

# --- GitHub App (optionnel, pour webhook real-time) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- Web Push (optionnel) ---
# Génère avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Backup R2 (optionnel) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=porterfield-backups
